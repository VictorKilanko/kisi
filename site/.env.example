# Kisi site — environment variables (copy to .env.local; NEVER commit real keys)
# In production these live in the Vercel project's Environment Variables.
#
# Every one of these is OPTIONAL. Without them the site still builds and runs;
# features that need them degrade honestly and tell the visitor the truth.

# --- Site ---
# Canonical origin for metadata, canonical URLs, JSON-LD and the sitemap.
# No trailing slash. Change this when the real domain points at Vercel.
NEXT_PUBLIC_SITE_URL=https://victorkilanko.com/kisi

# --- Mail (Resend) — how egg orders actually reach the farm ---
# Without these, /api/orders returns 503 and the Shop sends customers to the
# contact page rather than silently swallowing an order.
# Free tier: 3,000 emails/month — https://resend.com
RESEND_API_KEY=
# Where order enquiries and Bantu well-wishes are delivered.
FARM_INBOX=
# Verified sender. Resend's shared onboarding@resend.dev is fine for testing;
# use an address on your own verified domain in production.
MAIL_FROM=Kisi Farm <onboarding@resend.dev>

# --- Rate limiting (Upstash Redis) ---
# Without these the limiter falls back to in-memory, which does NOT work
# correctly on Vercel — each serverless instance keeps its own counter.
# Free tier is ample — https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Payments (docs/DONATION_INTEGRATION.md) ---
# TEST keys only. Live keys are additionally blocked in code
# (lib/payments/index.ts) until the wording review is complete.
PAYMENT_PROVIDER=paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sandbox-only helper: tier prices are unset until the owner decides them;
# this amount (NGN) lets the test flow run end-to-end. Remove at launch.
PAYMENTS_TEST_AMOUNT_NGN=1000

# Deliberately NOT honored unless the hard-coded lock in
# lib/payments/index.ts is also changed by a reviewed commit:
# PAYMENTS_ALLOW_LIVE=true
